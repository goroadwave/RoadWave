# Copy this file to .env.local and fill in real values.
# Find your keys at https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-secret-service-role-key

# Used by the cron route to authorize calls. Generate with: openssl rand -hex 32
CRON_SECRET=your-random-cron-secret

# Server-side ElevenLabs API key for /api/speak (text-to-speech narration on /tour).
# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Password gating /owner. The page is not linked from anywhere; you reach it
# at <site>/owner and enter this value. Sessions persist via a hashed token
# in localStorage — rotating this value invalidates all sessions.
OWNER_PASSWORD=pick-a-strong-shared-password

# Public origin used to build absolute URLs (notably the emailRedirectTo
# passed to supabase.auth.signUp). Set this in Vercel to the canonical
# HTTPS URL so confirmation emails always link to the right place.
NEXT_PUBLIC_SITE_URL=https://www.getroadwave.com
